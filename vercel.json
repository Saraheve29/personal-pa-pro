{
  "version": 2,
  "builds": [
    {
      "src": "api/ai.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/ai", "dest": "/api/ai.js" },
    { "src": "/api/ai/(.*)", "dest": "/api/ai.js" },
    { "src": "/assets/(.*)", "dest": "/dist/assets/$1" },
    { "src": "^/[^.]*$", "dest": "/dist/index.html" },
    { "src": "/(.*\\..*)", "dest": "/dist/$1" }
  ]
}
